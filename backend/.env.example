# Database
POSTGRES_USER=vixa
POSTGRES_PASSWORD=vixa_secret
POSTGRES_DB=vixa_ciam
DATABASE_URL=postgresql+asyncpg://vixa:vixa_secret@postgres:5432/vixa_ciam

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://vixa:vixa_secret@rabbitmq:5672/
RABBITMQ_USER=vixa
RABBITMQ_PASSWORD=vixa_secret

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_HOLD_AMOUNT_CENTS=100

# reCAPTCHA
RECAPTCHA_SECRET_KEY=your_recaptcha_secret

# SMS (Twilio mock for dev)
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (SMTP mock for dev)
EMAIL_PROVIDER=mock
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@vixa.platform

# Ost Infinity ACL
OST_INFINITY_BASE_URL=http://acl-service:8007/mock/ost-infinity
OST_INFINITY_API_KEY=ost_dev_key

GATEWAY_RATE_LIMIT=100
GATEWAY_RATE_WINDOW_SECONDS=60

AUTH_SERVICE_URL=http://auth-service:8001
ONBOARDING_SERVICE_URL=http://onboarding-service:8002
ORG_SITE_SERVICE_URL=http://org-site-service:8003
VERIFICATION_SERVICE_URL=http://verification-service:8004
PAYMENTS_SERVICE_URL=http://payments-service:8005
LICENSING_SERVICE_URL=http://licensing-service:8006
ACL_SERVICE_URL=http://acl-service:8007

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
