# Local development (no Docker) — copy to .env
DATABASE_URL=postgresql+asyncpg://vixa:vixa_secret@localhost:5432/vixa_ciam
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

STRIPE_SECRET_KEY=sk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_mock
STRIPE_HOLD_AMOUNT_CENTS=100

RECAPTCHA_SECRET_KEY=mock_recaptcha_secret
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@vixa.platform

OST_INFINITY_BASE_URL=http://localhost:8007/mock/ost-infinity
OST_INFINITY_API_KEY=ost_dev_key

GATEWAY_RATE_LIMIT=100
GATEWAY_RATE_WINDOW_SECONDS=60

AUTH_SERVICE_URL=http://localhost:8001
